 # ==========================================
# deaf-ic 環境変数テンプレート
# ==========================================
# 使用方法: このファイルを .env.local にコピーして値を埋める
# .env.local は .gitignore 対象。シークレットは絶対にコミットしないこと

# --- Supabase（必須） ---
# Supabase Dashboard > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- アプリURL（必須） ---
# ローカル: http://localhost:6001
# 本番: https://app.deaf-ic.org 等
NEXT_PUBLIC_APP_URL=http://localhost:6001

# --- Anthropic Claude API（任意） ---
# 設定するとAI診断・PDF解析が有効。未設定なら該当機能は非表示
ANTHROPIC_API_KEY=

# --- Resend メール送信（任意） ---
# 招待メール・リマインダー送信で使用。未設定ならメール送信機能は無効
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# --- Cron（必須） ---
# Supabase pg_cron → Vault に登録 + Vercel env にも同じ値を投入
CRON_SECRET=

# --- PWA Web Push（任意。未設定なら Push 通知は無効、メールは通常通り） ---
# 生成: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-contact@example.com
# クライアントから読むため NEXT_PUBLIC_ 版も同じ公開鍵を入れる
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
